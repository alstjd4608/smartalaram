<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/add_custom_quiz"
        android:textColor="@color/text_primary"
        android:textSize="22sp"
        android:fontFamily="sans-serif-medium" />

    <View
        android:layout_width="40dp"
        android:layout_height="3dp"
        android:background="@color/primary"
        android:layout_marginTop="8dp" />

    <!-- Question Input -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/quiz_question_label"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium"
        android:layout_marginTop="20dp" />

    <EditText
        android:id="@+id/etQuizQuestion"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/bg_input"
        android:hint="@string/quiz_question_hint"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_hint"
        android:textSize="15sp"
        android:paddingHorizontal="16dp"
        android:fontFamily="sans-serif"
        android:maxLines="2"
        android:inputType="text"
        android:layout_marginTop="8dp" />

    <!-- Options Section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/quiz_options_label"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium"
        android:layout_marginTop="20dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/quiz_correct_hint"
        android:textColor="@color/text_hint"
        android:textSize="12sp"
        android:layout_marginTop="4dp" />

    <!-- Option 1 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="12dp">

        <TextView
            android:id="@+id/markerCorrect1"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="✓"
            android:textColor="@color/quiz_correct"
            android:textSize="14sp"
            android:fontFamily="sans-serif-bold"
            android:gravity="center"
            android:background="@drawable/bg_quiz_correct"
            android:clickable="true"
            android:focusable="true" />

        <EditText
            android:id="@+id/etOption1"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@drawable/bg_input"
            android:hint="@string/option_1_hint"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="14sp"
            android:paddingHorizontal="14dp"
            android:fontFamily="sans-serif"
            android:maxLines="1"
            android:inputType="text"
            android:layout_marginStart="10dp" />
    </LinearLayout>

    <!-- Option 2 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="8dp">

        <TextView
            android:id="@+id/markerCorrect2"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="2"
            android:textColor="@color/text_hint"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:background="@drawable/bg_day_chip"
            android:clickable="true"
            android:focusable="true" />

        <EditText
            android:id="@+id/etOption2"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@drawable/bg_input"
            android:hint="@string/option_2_hint"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="14sp"
            android:paddingHorizontal="14dp"
            android:fontFamily="sans-serif"
            android:maxLines="1"
            android:inputType="text"
            android:layout_marginStart="10dp" />
    </LinearLayout>

    <!-- Option 3 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="8dp">

        <TextView
            android:id="@+id/markerCorrect3"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="3"
            android:textColor="@color/text_hint"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:background="@drawable/bg_day_chip"
            android:clickable="true"
            android:focusable="true" />

        <EditText
            android:id="@+id/etOption3"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@drawable/bg_input"
            android:hint="@string/option_3_hint"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="14sp"
            android:paddingHorizontal="14dp"
            android:fontFamily="sans-serif"
            android:maxLines="1"
            android:inputType="text"
            android:layout_marginStart="10dp" />
    </LinearLayout>

    <!-- Option 4 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="8dp">

        <TextView
            android:id="@+id/markerCorrect4"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="4"
            android:textColor="@color/text_hint"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:background="@drawable/bg_day_chip"
            android:clickable="true"
            android:focusable="true" />

        <EditText
            android:id="@+id/etOption4"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@drawable/bg_input"
            android:hint="@string/option_4_hint"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="14sp"
            android:paddingHorizontal="14dp"
            android:fontFamily="sans-serif"
            android:maxLines="1"
            android:inputType="text"
            android:layout_marginStart="10dp" />
    </LinearLayout>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:layout_marginTop="24dp">

        <TextView
            android:id="@+id/btnCancelQuiz"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="취소"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:paddingHorizontal="20dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btnSaveQuiz"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="저장"
            android:textColor="@color/text_on_primary"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:paddingHorizontal="28dp"
            android:background="@drawable/bg_button_primary"
            android:layout_marginStart="12dp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>
</LinearLayout>
